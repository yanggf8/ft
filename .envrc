# Auto-fetch on entering project directory (requires direnv)
# Install: sudo apt install direnv / brew install direnv
# Shell hook: eval "$(direnv hook zsh)" in ~/.zshrc

# Check for remote changes silently
if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null; then
  git fetch --quiet origin 2>/dev/null &
  BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
  if [[ "$BEHIND" -gt 0 ]]; then
    echo "⚠️  FortuneT: $BEHIND new commit(s) on origin/main — consider git pull"
  fi
fi

# Check gh push access
if command -v gh &>/dev/null; then
  ACTIVE=$(gh api user --jq .login 2>/dev/null || echo "")
  if [[ -n "$ACTIVE" ]]; then
    PERM=$(gh api repos/yanggf8/ft/collaborators/$ACTIVE/permission --jq .permission 2>/dev/null || echo "none")
    if [[ "$PERM" != "admin" && "$PERM" != "write" ]]; then
      echo "⚠️  gh account '$ACTIVE' has no push access — run: gh auth switch -u <correct-account>"
    fi
  fi
fi
